# =====================================================
# 复制本文件为 .env.local 后填入实际值
# .env.local 已在 .gitignore，不会提交代码仓库
# 接口按推荐开通顺序排列
# =====================================================

# ─────────────────────────────────────────────────────
# 【1】【2】企查查核心接口  —— 必开，填好下面两个 Key 即同时生效
# 注册：https://openapi.qcc.com/  控制台右上角「接口调用凭证(Key)」
#   ApiCode 886 企业模糊搜索 (0.10元/次) → 搜索框 / 供应商排名列表
#   ApiCode 410 企业工商信息 (0.20元/次) → 供应商卡片 / 详情卡 / 四维评分
# 注：Key 全账号一套，所有接口共用，不需要为每个接口单独配 Key
# ─────────────────────────────────────────────────────
QCC_APP_KEY=
QCC_SECRET_KEY=

# ─────────────────────────────────────────────────────
# 【可选增强】化工网行业验证 —— 对应结果区「交叉验证」标签
# 暂不启用可留空
# ─────────────────────────────────────────────────────
CHEMNET_API_KEY=

# 买化塑无需 Key，将 Excel 放入 data/ibuychem/ 目录即自动启用

# ─────────────────────────────────────────────────────
# 【调试】排查字段映射问题用，设为 1 时控制台打印企查查原始返回字段
# 排查完记得改回 0 或删除
# ─────────────────────────────────────────────────────
QCC_DEBUG=0
